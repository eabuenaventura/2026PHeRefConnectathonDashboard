# FHIR R4 server base URL. Must be NEXT_PUBLIC_ because the dashboard fetches
# directly from the browser (client-side). The server must allow CORS.
NEXT_PUBLIC_FHIR_BASE_URL=https://cdr.pheref.fhirlab.net/fhir

# Reporting calendar year for the submission-status matrix.
# Leave blank to auto-detect the busiest year from ServiceRequest.authoredOn.
NEXT_PUBLIC_REPORTING_YEAR=
